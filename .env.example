# ──────────────────────────────────────────────────
#  Stadium Pulse AI — Environment Variables
# ──────────────────────────────────────────────────
# Copy to .env and fill in values.

# Server
PORT=3000
NODE_ENV=development

# Google Gemini (optional — app works offline without it)
GEMINI_API_KEY=GEMINI_API_KEY1
GEMINI_MODEL=gemini-2.0-flash

# AI tuning
AI_MAX_TOKENS=1024
AI_TIMEOUT_MS=15000
AI_CACHE_TTL_MS=300000
AI_CACHE_MAX=300

# Rate limiting
RATE_LIMIT_WINDOW_MS=60000
RATE_LIMIT_MAX=100
AI_RATE_LIMIT_MAX=20

# Simulation
SIMULATION_TICK_MS=2000
SIMULATION_SCENARIO_SPEED=fast
